{
  "name": "flams-analytics-pro",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm --prefix ./server run dev\" \"npm --prefix ./client run dev\"",
    "install:all": "npm --prefix ./client install --include=dev && npm --prefix ./server install --include=dev",
    "build": "npm --prefix ./client run build && npm --prefix ./server run build",
    "postinstall": "npm run install:all && npm run build",
    "start": "npm --prefix ./server run start"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "multer": "^2.0.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
